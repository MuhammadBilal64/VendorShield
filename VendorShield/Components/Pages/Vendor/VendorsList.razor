@page "/vendors"
@using VendorShield.IService
@using VendorShield.Model
@using VendorShield.Utility
@inject IVendorService VendorService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Buyer,Viewer")]
<h3 class="page-title mb-4">Vendors</h3>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="fw-semibold">Vendor List</div>
            <button class="btn btn-primary px-3" @onclick="GoToAddVendor">
                + Add Vendor
            </button>
        </div>

        <div class="border rounded-3 bg-light p-3 mb-4">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label mb-1 fw-semibold">Search</label>
                    <input class="form-control"
                           placeholder="Search by vendor name..."
                           @bind="searchText"
                           @bind:event="oninput"
                           disabled="@(vendors == null)" />
                </div>

                <div class="col-md-2">
                    <label class="form-label mb-1 fw-semibold">Category</label>
                    <select class="form-select" @bind="selectedCategory" disabled="@(vendors == null)">
                        <option value="All">All</option>
                        @foreach (var c in categories)
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label mb-1 fw-semibold">Region</label>
                    <select class="form-select" @bind="selectedRegion" disabled="@(vendors == null)">
                        <option value="All">All</option>
                        @foreach (var r in regions)
                        {
                            <option value="@r">@r</option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label mb-1 fw-semibold">Status</label>
                    <select class="form-select" @bind="selectedStatus" disabled="@(vendors == null)">
                        <option value="All">All</option>
                        <option value="Active">Active</option>
                        <option value="OnHold">OnHold</option>
                        <option value="Blacklisted">Blacklisted</option>
                    </select>
                </div>

                <div class="col-md-2 d-grid">
                    <button class="btn btn-outline-secondary"
                            @onclick="ClearFilters"
                            disabled="@(vendors == null)">
                        Clear filters
                    </button>
                </div>
            </div>
        </div>

        @if (vendors == null)
        {
            <div class="text-center py-5 text-muted">
                <div class="spinner-border" role="status" aria-label="Loading"></div>
                <div class="mt-2">Loading vendors...</div>
            </div>
        }
        else if (!vendors.Any())
        {
            <div class="text-center py-5 text-muted">
                No vendors available.
            </div>
        }
        else
        {
            <div class="table-responsive">
                @if (!FilteredVendors.Any())
                {
                    <div class="text-center py-5 text-muted">
                        No vendors match your filters.
                    </div>
                }
                else
                {
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Status</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th class="text-center">Performance</th>
                                <th class="text-center">Risk</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in FilteredVendors)
                            {
                                <tr>
                                    <td class="fw-semibold">@v.Name</td>
                                    <td>@v.Category</td>
                                    <td>
                                        <span class="badge @GetStatusClass(v.Status)">
                                            @v.Status
                                        </span>
                                    </td>
                                    <td>@v.Email</td>
                                    <td>@v.Phone</td>
                                    <td class="text-center">
                                        <span class="badge @GetPerformanceClass(v.PerformanceScore)">
                                            @v.PerformanceScore.ToString("0.0")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @GetRiskClass(v.RiskScore)">
                                            @GetRiskLevel(v.RiskScore)
                                        </span>
                                        <div class="text-muted small">@v.RiskScore.ToString("0.0")%</div>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary me-1"
                                                @onclick="() => GoToEdit(v.Id)">
                                            Edit
                                        </button>
                                        <button class="btn btn-sm btn-outline-info me-1"
                                                @onclick="() => GoToDetails(v.Id)">
                                            Details
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger"
                                                @onclick="() => ConfirmDelete(v.Id)">
                                            Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<Vendor>? vendors = null;
    private List<string> categories = new();
    private List<string> regions = new();

    private string searchText = "";
    private string selectedCategory = "All";
    private string selectedRegion = "All";
    private string selectedStatus = "All";

    private List<Vendor> FilteredVendors
    {
        get
        {
            if (vendors == null) return new List<Vendor>();

            IEnumerable<Vendor> query = vendors;

            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(v =>
                    !string.IsNullOrWhiteSpace(v.Name) &&
                    v.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase));
            }

            if (selectedCategory != "All")
            {
                query = query.Where(v =>
                    !string.IsNullOrWhiteSpace(v.Category) &&
                    string.Equals(v.Category, selectedCategory, StringComparison.OrdinalIgnoreCase));
            }

            if (selectedRegion != "All")
            {
                query = query.Where(v =>
                    !string.IsNullOrWhiteSpace(v.Region) &&
                    string.Equals(v.Region, selectedRegion, StringComparison.OrdinalIgnoreCase));
            }

            if (selectedStatus != "All" &&
                Enum.TryParse<VendorStatus>(selectedStatus, out var status))
            {
                query = query.Where(v => v.Status == status);
            }

            return query.ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await ReloadVendorsAsync();
    }

    private void GoToAddVendor()
    {
        NavigationManager.NavigateTo("/vendor-add");
    }

    private void GoToEdit(int id)
    {
        NavigationManager.NavigateTo($"/vendor-edit/{id}");
    }

    private void GoToDetails(int id)
    {
        NavigationManager.NavigateTo($"/vendor-details/{id}");
    }

    private async Task ConfirmDelete(int id)
    {
        if (await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this vendor?"))
        {
            await VendorService.DeleteVendorAsync(id);
            await ReloadVendorsAsync();
        }
    }

    private async Task ReloadVendorsAsync()
    {
        vendors = await VendorService.GetAllVendorsAsync();

        categories = vendors
            .Select(v => v.Category)
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(c => c)
            .ToList();

        regions = vendors
            .Select(v => v.Region)
            .Where(r => !string.IsNullOrWhiteSpace(r))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(r => r)
            .ToList();
    }

    private void ClearFilters()
    {
        searchText = "";
        selectedCategory = "All";
        selectedRegion = "All";
        selectedStatus = "All";
    }

    private string GetRiskClass(double risk)
    {
        if (risk <= 20)
            return "bg-success";
        else if (risk <= 50)
            return "bg-warning text-dark";
        else
            return "bg-danger";
    }

    private string GetRiskLevel(double risk)
    {
        if (risk <= 20) return "Low";
        if (risk <= 50) return "Medium";
        return "High";
    }

    private string GetStatusClass(VendorStatus status)
    {
        return status switch
        {
            VendorStatus.Active => "bg-success",
            VendorStatus.OnHold => "bg-warning text-dark",
            VendorStatus.Blacklisted => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private string GetPerformanceClass(double score)
    {
        if (score >= 80)
            return "bg-success";
        else if (score >= 60)
            return "bg-warning";
        else
            return "bg-danger";
    }
}

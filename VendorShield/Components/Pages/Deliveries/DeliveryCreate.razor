@page "/deliveries/create/{poId:int}"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Buyer")]

@using VendorShield.IService
@using VendorShield.Model
@inject IPurchaseOrderService PurchaseOrderService
@inject IDeliveryService DeliveryService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<h3 class="page-title mb-4">Add Delivery</h3>

@if (purchaseOrder == null)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border" role="status" aria-label="Loading"></div>
        <div class="mt-2">Loading purchase order...</div>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="row mb-4">
                <div class="col-md-4 mb-2">
                    <div class="text-muted small">PO Number</div>
                    <div class="fw-semibold">@purchaseOrder.PoNumber</div>
                </div>
                <div class="col-md-4 mb-2">
                    <div class="text-muted small">Vendor</div>
                    <div class="fw-semibold">@purchaseOrder.Vendor?.Name</div>
                </div>
                <div class="col-md-4 mb-2">
                    <div class="text-muted small">Expected Delivery</div>
                    <div class="fw-semibold">@(purchaseOrder.ExpectedDeliveryDate?.ToShortDateString() ?? "N/A")</div>
                </div>
            </div>

                <div class="row mb-4">
                    <div class="col-md-4 mb-2">
                        <div class="text-muted small">Ordered Quantity</div>
                        <div class="fw-semibold">@orderedQty</div>
                    </div>
                    <div class="col-md-4 mb-2">
                        <div class="text-muted small">Delivered / Ordered</div>
                        <div class="fw-semibold">
                            @(orderedQty > 0 ? $"{model.DeliveredQuantity} / {orderedQty}" : "N/A")
                        </div>
                    </div>
                    <div class="col-md-4 mb-2">
                        <div class="text-muted small">Defective Quantity</div>
                        <div class="fw-semibold">@model.DefectiveQuantity</div>
                    </div>
                </div>

            <EditForm Model="model" OnValidSubmit="HandleSubmit">
                @if (model.DefectiveQuantity > 0)
                {
                    <div class="alert alert-warning mb-4" role="alert">
                        Defective quantity is set to @model.DefectiveQuantity. This delivery will be treated as not high-quality.
                    </div>
                }
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Actual Delivery Date</label>
                        <InputDate class="form-control" @bind-Value="model.ActualDeliveryDate" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Delivered Quantity</label>
                        <InputNumber class="form-control" @bind-Value="model.DeliveredQuantity" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Defective Quantity</label>
                        <InputNumber class="form-control" @bind-Value="model.DefectiveQuantity" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Notes</label>
                    <InputText class="form-control" @bind-Value="model.Notes" />
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <button type="button" class="btn btn-outline-secondary px-4" @onclick="GoBack">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-success px-4">
                        Save Delivery
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    [Parameter]
    public int poId { get; set; }

    private PurchaseOrder? purchaseOrder;

    private Delivery model = new Delivery();
    private int orderedQty;

    protected override async Task OnInitializedAsync()
    {
        purchaseOrder = await PurchaseOrderService.GetPurchaseOrderByIdAsync(poId);
        if (purchaseOrder == null)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Purchase order not found!");
            NavigationManager.NavigateTo("/purchaseorders");
            return;
        }

        orderedQty = purchaseOrder.Lines?.Sum(l => l.Quantity) ?? 0;

        model = new Delivery
        {
            PurchaseOrderId = poId,
            ActualDeliveryDate = DateTime.Now,
            DeliveredQuantity = 0,
            DefectiveQuantity = 0,
            Notes = null
        };
    }

    private void GoBack() => NavigationManager.NavigateTo($"/purchaseorders/details/{poId}");

    private async Task HandleSubmit()
    {
        var success = await DeliveryService.AddDeliveryAsync(model);
        if (!success)
        {
            await JSRuntime.InvokeVoidAsync("alert", "Failed to add delivery. Check quantities and PO id.");
            return;
        }

        await JSRuntime.InvokeVoidAsync("alert", "Delivery added successfully.");
        NavigationManager.NavigateTo($"/purchaseorders/details/{poId}");
    }
}


@page "/deliveries"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Buyer")]

@using VendorShield.IService
@using VendorShield.Model
@inject IDeliveryService DeliveryService
@inject NavigationManager NavigationManager

<h3 class="page-title mb-4">Deliveries</h3>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        @if (deliveries == null)
        {
            <div class="text-center py-5 text-muted">
                <div class="spinner-border" role="status" aria-label="Loading"></div>
                <div class="mt-2">Loading deliveries...</div>
            </div>
        }
        else if (!deliveries.Any())
        {
            <div class="text-center py-5 text-muted">
                No deliveries available.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Date</th>
                            <th>Vendor</th>
                            <th>PO</th>
                            <th class="text-end">Delivered / Ordered</th>
                            <th class="text-end">Defective</th>
                            <th class="text-end">Delay Days</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var d in deliveries)
                        {
                            var defectiveClass = d.DefectiveQuantity > 0 ? "table-warning" : "";
                            var orderedQty = d.PurchaseOrder?.Lines?.Sum(l => l.Quantity) ?? 0;
                            var delayDays = d.PurchaseOrder?.ExpectedDeliveryDate.HasValue == true
                                ? (int?)(d.ActualDeliveryDate - d.PurchaseOrder.ExpectedDeliveryDate.Value).Days
                                : null;

                            <tr class="@defectiveClass">
                                <td>@d.ActualDeliveryDate.ToShortDateString()</td>
                                <td class="fw-semibold">@d.PurchaseOrder?.Vendor?.Name</td>
                                <td>@d.PurchaseOrder?.PoNumber</td>
                                <td class="text-end">
                                    @d.DeliveredQuantity / @orderedQty
                                </td>
                                <td class="text-end">
                                    @d.DefectiveQuantity
                                    @if (d.DefectiveQuantity > 0)
                                    {
                                        <span class="badge bg-warning text-dark ms-2">Issue</span>
                                    }
                                </td>
                                <td class="text-end">
                                    @(delayDays.HasValue ? delayDays.Value.ToString() : "N/A")
                                </td>
                                <td style="max-width: 340px;">
                                    <span class="text-muted">@d.Notes</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private List<Delivery>? deliveries;

    protected override async Task OnInitializedAsync()
    {
        deliveries = await DeliveryService.GetAllDeliveriesAsync();
    }

    private void GoHome() => NavigationManager.NavigateTo("/");
}


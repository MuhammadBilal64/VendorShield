@page "/"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin,Buyer,Viewer")]

@using VendorShield.IService
@using VendorShield.Model
@using VendorShield.Utility
@inject IVendorService VendorService
@inject IIncidentService IncidentService
@inject IScoringService ScoringService

<h3 class="page-title mb-4">Dashboard</h3>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Category</label>
                <select class="form-select" value="@selectedCategory" @onchange="CategoryChanged">
                    <option value="">All</option>
                    @foreach (var c in categories)
                    {
                        <option value="@c">@c</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Region</label>
                <select class="form-select" value="@selectedRegion" @onchange="RegionChanged">
                    <option value="">All</option>
                    @foreach (var r in regions)
                    {
                        <option value="@r">@r</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Risk Level</label>
                <select class="form-select" value="@selectedRisk" @onchange="RiskChanged">
                    <option value="">All</option>
                    <option value="Low">Low</option>
                    <option value="Medium">Medium</option>
                    <option value="High">High</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Time Period</label>
                <select class="form-select" value="@selectedTimePeriod" @onchange="TimePeriodChanged">
                    <option value="3">Last 3 months</option>
                    <option value="6">Last 6 months</option>
                    <option value="12">Last 12 months</option>
                </select>
            </div>
        </div>
    </div>
</div>

@if (loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border" role="status" aria-label="Loading"></div>
        <div class="mt-2">Loading dashboard...</div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="p-3 bg-primary text-white rounded-3">
                <div class="small text-white-50">Total Vendors</div>
                <div class="fs-4 fw-semibold">@filteredRows.Count</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 bg-danger text-white rounded-3">
                <div class="small text-white-50">High Risk Vendors</div>
                <div class="fs-4 fw-semibold">@filteredRows.Count(r => r.Score.RiskLevel == "High")</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 bg-success text-white rounded-3">
                <div class="small text-white-50">Average On-Time %</div>
                <div class="fs-4 fw-semibold">@GetAvgOnTime(filteredRows).ToString("0.0")%</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="p-3 bg-warning text-dark rounded-3">
                <div class="small" style="opacity: 0.75;">Open Incidents</div>
                <div class="fs-4 fw-semibold">@openIncidentsCount</div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div class="fw-semibold">Vendor Ranking</div>
                <div class="text-muted small">Time window: last @monthsBack months</div>
            </div>

            @if (!filteredRows.Any())
            {
                <div class="text-center py-5 text-muted">
                    No vendors match the selected filters.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Vendor Name</th>
                                <th>Category</th>
                                <th>Region</th>
                                <th class="text-end">OverallScore</th>
                                <th>RiskLevel</th>
                                <th class="text-end">OnTime%</th>
                                <th class="text-end">IncidentCount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in filteredRows.OrderByDescending(r => r.Score.OverallScore))
                            {
                                <tr>
                                    <td class="fw-semibold">@row.Vendor.Name</td>
                                    <td>@row.Vendor.Category</td>
                                    <td>@row.Vendor.Region</td>
                                    <td class="text-end fw-semibold">@row.Score.OverallScore.ToString("0.0")</td>
                                    <td>
                                        <span class="badge @GetRiskClass(row.Score.RiskScore)">
                                            @row.Score.RiskLevel
                                        </span>
                                    </td>
                                    <td class="text-end">@row.Score.OnTimeScore.ToString("0.0")%</td>
                                    <td class="text-end">@row.Score.IncidentCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    private bool loading = true;

    private string? selectedCategory;
    private string? selectedRegion;
    private string? selectedRisk;
    private int monthsBack = 6;
    private string selectedTimePeriod = "6";

    private List<Vendor> vendors = new();
    private List<VendorRankingRow> allRows = new();
    private List<VendorRankingRow> filteredRows = new();

    private HashSet<string> categories = new();
    private HashSet<string> regions = new();

    private int openIncidentsCount;

    private List<Incident> allIncidents = new();

    private static (DateTime From, DateTime To) GetRange(int monthsBack)
    {
        var to = DateTime.Now;
        var from = to.AddMonths(-monthsBack);
        return (from, to);
    }

    protected override async Task OnInitializedAsync()
    {
        loading = true;

        vendors = await VendorService.GetAllVendorsAsync();
        categories = vendors.Select(v => v.Category).Where(c => !string.IsNullOrWhiteSpace(c)).ToHashSet();
        regions = vendors.Select(v => v.Region).Where(r => !string.IsNullOrWhiteSpace(r)).ToHashSet();

        allIncidents = await IncidentService.GetAllIncidentsAsync();

        var (from, to) = GetRange(monthsBack);

        await RebuildRowsAsync(from, to);

        filteredRows = allRows;
        openIncidentsCount = CalculateOpenIncidentsCount(filteredRows, from, to);

        loading = false;
    }

    private void ApplyFilters()
    {
        filteredRows = allRows
            .Where(r =>
                (string.IsNullOrWhiteSpace(selectedCategory) || r.Vendor.Category == selectedCategory) &&
                (string.IsNullOrWhiteSpace(selectedRegion) || r.Vendor.Region == selectedRegion) &&
                (string.IsNullOrWhiteSpace(selectedRisk) || r.Score.RiskLevel == selectedRisk))
            .ToList();

        // Re-count open incidents for filtered vendors; use the same scoring window.
        var (from, to) = GetRange(monthsBack);
        openIncidentsCount = CalculateOpenIncidentsCount(filteredRows, from, to);
    }

    private void CategoryChanged(ChangeEventArgs e)
    {
        selectedCategory = e.Value?.ToString();
        ApplyFilters();
    }

    private void RegionChanged(ChangeEventArgs e)
    {
        selectedRegion = e.Value?.ToString();
        ApplyFilters();
    }

    private void RiskChanged(ChangeEventArgs e)
    {
        selectedRisk = e.Value?.ToString();
        ApplyFilters();
    }

    private int CalculateOpenIncidentsCount(List<VendorRankingRow> rows, DateTime from, DateTime to)
    {
        var vendorIds = rows.Select(r => r.Vendor.Id).ToHashSet();
        return allIncidents.Count(i =>
            i.Status == IncidentStatus.Open &&
            vendorIds.Contains(i.VendorId) &&
            i.IncidentDate >= from &&
            i.IncidentDate <= to);
    }

    private static double GetAvgOnTime(List<VendorRankingRow> rows)
    {
        if (rows.Count == 0) return 0;
        return rows.Average(r => r.Score.OnTimeScore);
    }

    private string GetRiskClass(double riskScore)
    {
        if (riskScore <= 20) return "bg-success";
        if (riskScore <= 50) return "bg-warning text-dark";
        return "bg-danger";
    }

    private class VendorRankingRow
    {
        public required Vendor Vendor { get; set; }
        public required VendorScoreResult Score { get; set; }
    }

    private async Task RebuildRowsAsync(DateTime from, DateTime to)
    {
        allRows.Clear();
        foreach (var v in vendors)
        {
            var score = await ScoringService.CalculateVendorScoreAsync(v.Id, from, to);
            allRows.Add(new VendorRankingRow
            {
                Vendor = v,
                Score = score
            });
        }
    }

    private void TimePeriodChanged(ChangeEventArgs e)
    {
        selectedTimePeriod = e.Value?.ToString() ?? "6";
        if (!int.TryParse(selectedTimePeriod, out monthsBack))
        {
            monthsBack = 6;
        }

        // Recalculate scoring rows + incident counts for the new time window.
        _ = InvokeAsync(async () =>
        {
            loading = true;
            StateHasChanged();

            var (from, to) = GetRange(monthsBack);
            await RebuildRowsAsync(from, to);

            ApplyFilters();
            openIncidentsCount = CalculateOpenIncidentsCount(filteredRows, from, to);

            loading = false;
            StateHasChanged();
        });
    }
}


@page "/pending-access"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        <p class="text-muted mb-0">
            Your account is pending role assignment. Please contact your administrator to get access.
        </p>
    </div>
</div>

@code {
    // Intentionally empty: this page only shows the pending-access message.
}


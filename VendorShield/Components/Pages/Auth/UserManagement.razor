@page "/admin/users"
@rendermode InteractiveServer

@using System.Linq
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using VendorShield.Model

@attribute [Authorize(Roles = "Admin")]

@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject IJSRuntime JSRuntime

<h3 class="page-title mb-4">User Management</h3>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">
        @if (loading)
        {
            <div class="text-center py-5 text-muted">
                <div class="spinner-border" role="status" aria-label="Loading"></div>
                <div class="mt-2">Loading users...</div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Email</th>
                            <th>Name</th>
                            <th>Current Roles</th>
                            <th style="width: 220px;">Change Role</th>
                            <th class="text-end" style="width: 120px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in userRows)
                        {
                            <tr>
                                <td class="fw-semibold">@row.User.Email</td>
                                <td>@($"{row.User.FirstName} {row.User.LastName}".Trim())</td>
                                <td>
                                    @if (row.Roles.Count == 0)
                                    {
                                        <span class="text-muted small">No role</span>
                                    }
                                    else
                                    {
                                        @foreach (var r in row.Roles)
                                        {
                                            <span class="badge bg-secondary me-1">@r</span>
                                        }
                                    }
                                </td>
                                <td>
                                    <select class="form-select form-select-sm" value="@row.SelectedRole"
                                            @onchange="e => OnRoleSelectionChanged(row.User.Id, e.Value?.ToString())">
                                        @foreach (var role in availableRoles)
                                        {
                                            <option value="@role">@role</option>
                                        }
                                    </select>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-success"
                                            @onclick="() => SaveRoleAsync(row.User.Id)"
                                            disabled="@savingUserIds.Contains(row.User.Id)">
                                        @if (savingUserIds.Contains(row.User.Id))
                                        {
                                            <span class="spinner-border spinner-border-sm" role="status" aria-label="Saving"></span>
                                        }
                                        else
                                        {
                                            <span>Save</span>
                                        }
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private bool loading = true;
    private List<UserRow> userRows = new();
    private HashSet<string> savingUserIds = new();

    private static readonly string[] AllowedRoles = { "Admin", "Buyer", "Viewer" };
    private static readonly HashSet<string> AllowedRoleSet =
        new HashSet<string>(AllowedRoles, StringComparer.OrdinalIgnoreCase);

    private List<string> availableRoles = new();

    private sealed class UserRow
    {
        public required ApplicationUser User { get; set; }
        public List<string> Roles { get; set; } = new();
        public string SelectedRole { get; set; } = "Viewer";
    }

    protected override async Task OnInitializedAsync()
    {
        loading = true;

        var roleNames = await RoleManager.Roles.Select(r => r.Name).ToListAsync();
        availableRoles = roleNames
            .Where(n => !string.IsNullOrWhiteSpace(n) && AllowedRoleSet.Contains(n))
            .Select(n => n!)
            .ToList();
        if (availableRoles.Count == 0)
            availableRoles = AllowedRoles.ToList();

        var users = await UserManager.Users.ToListAsync();
        userRows = new List<UserRow>(users.Count);

        foreach (var user in users)
        {
            var roles = await UserManager.GetRolesAsync(user);
            var allowedCurrentRole = roles.FirstOrDefault(r => AllowedRoleSet.Contains(r));

            userRows.Add(new UserRow
            {
                User = user,
                Roles = roles.ToList(),
                SelectedRole = allowedCurrentRole ?? availableRoles.FirstOrDefault() ?? "Viewer"
            });
        }

        loading = false;
    }

    private void OnRoleSelectionChanged(string userId, string? selectedRole)
    {
        if (string.IsNullOrWhiteSpace(selectedRole)) return;

        var row = userRows.FirstOrDefault(x => x.User.Id == userId);
        if (row == null) return;
        if (!AllowedRoleSet.Contains(selectedRole)) return;

        row.SelectedRole = selectedRole;
    }

    private async Task SaveRoleAsync(string userId)
    {
        var row = userRows.FirstOrDefault(x => x.User.Id == userId);
        if (row == null) return;

        var selectedRole = row.SelectedRole;
        if (!AllowedRoleSet.Contains(selectedRole)) return;

        try
        {
            savingUserIds.Add(userId);

            // Remove any existing role among the allowed set.
            var currentRoles = await UserManager.GetRolesAsync(row.User);
            foreach (var role in currentRoles.Where(r => AllowedRoleSet.Contains(r)))
            {
                await UserManager.RemoveFromRoleAsync(row.User, role);
            }

            // Add the newly selected role (always add one of the allowed roles).
            await UserManager.AddToRoleAsync(row.User, selectedRole);

            row.Roles = (await UserManager.GetRolesAsync(row.User)).ToList();

            await JSRuntime.InvokeVoidAsync("alert", "User role updated successfully.");
        }
        finally
        {
            savingUserIds.Remove(userId);
            StateHasChanged();
        }
    }
}

